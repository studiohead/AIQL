{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AIQL AST Schema",
  "type": "object",
  "required": ["type", "body"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["Program"]
    },
    "body": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Statement"
      }
    }
  },
  "definitions": {
    "Statement": {
      "type": "object",
      "oneOf": [
        { "$ref": "#/definitions/LoadStatement" },
        { "$ref": "#/definitions/PipelineStatement" },
        { "$ref": "#/definitions/CallStatement" },
        { "$ref": "#/definitions/ConditionalStatement" },
        { "$ref": "#/definitions/ReturnStatement" }
      ]
    },
    "LoadStatement": {
      "type": "object",
      "required": ["type", "variable", "source"],
      "properties": {
        "type": { "const": "LoadStatement" },
        "variable": { "type": "string" },
        "source": { "type": "string" },
        "query": { "type": "string" },
        "metadata": { "$ref": "#/definitions/Metadata" }
      },
      "additionalProperties": false
    },
    "PipelineStatement": {
      "type": "object",
      "required": ["type", "variable", "source", "steps"],
      "properties": {
        "type": { "const": "PipelineStatement" },
        "variable": { "type": "string" },
        "source": { "type": "string" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/PipelineStep" }
        },
        "metadata": { "$ref": "#/definitions/Metadata" }
      },
      "additionalProperties": false
    },
    "PipelineStep": {
      "type": "object",
      "oneOf": [
        { "$ref": "#/definitions/Operation" },
        { "$ref": "#/definitions/CallStatement" }
      ]
    },
    "Operation": {
      "type": "object",
      "required": ["type", "name", "inputs", "output", "params"],
      "properties": {
        "type": { "const": "Operation" },
        "name": { "type": "string" },
        "inputs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "output": { "type": "string" },
        "params": { "type": "object" },
        "metadata": { "$ref": "#/definitions/Metadata" }
      },
      "additionalProperties": false
    },
    "CallStatement": {
      "type": "object",
      "required": ["type", "call_type", "action", "inputs"],
      "properties": {
        "type": { "const": "CallStatement" },
        "call_type": {
          "type": "string",
          "enum": ["model", "function", "visualize"]
        },
        "action": { "type": "string" },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "params": { "type": "object" },
        "metadata": { "$ref": "#/definitions/Metadata" }
      },
      "additionalProperties": false
    },
    "ConditionalStatement": {
      "type": "object",
      "required": ["type", "condition", "then_body"],
      "properties": {
        "type": { "const": "ConditionalStatement" },
        "condition": { "$ref": "#/definitions/Expression" },
        "then_body": {
          "type": "array",
          "items": { "$ref": "#/definitions/Statement" }
        },
        "else_body": {
          "type": "array",
          "items": { "$ref": "#/definitions/Statement" }
        },
        "metadata": { "$ref": "#/definitions/Metadata" }
      },
      "additionalProperties": false
    },
    "ReturnStatement": {
      "type": "object",
      "required": ["type", "variable"],
      "properties": {
        "type": { "const": "ReturnStatement" },
        "variable": { "type": "string" },
        "metadata": { "$ref": "#/definitions/Metadata" }
      },
      "additionalProperties": false
    },
    "Expression": {
      "oneOf": [
        { "$ref": "#/definitions/BinaryExpression" },
        { "$ref": "#/definitions/LogicalExpression" },
        { "$ref": "#/definitions/Variable" },
        { "$ref": "#/definitions/Literal" }
      ]
    },
    "BinaryExpression": {
      "type": "object",
      "required": ["type", "operator", "left", "right"],
      "properties": {
        "type": { "const": "BinaryExpression" },
        "operator": {
          "type": "string",
          "enum": ["<", ">", "<=", ">=", "==", "!=", "!="]
        },
        "left": { "$ref": "#/definitions/Expression" },
        "right": { "$ref": "#/definitions/Expression" }
      },
      "additionalProperties": false
    },
    "LogicalExpression": {
      "type": "object",
      "required": ["type", "operator", "operands"],
      "properties": {
        "type": { "const": "LogicalExpression" },
        "operator": {
          "type": "string",
          "enum": ["AND", "OR", "NOT"]
        },
        "operands": {
          "type": "array",
          "items": { "$ref": "#/definitions/Expression" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "Variable": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": { "const": "Variable" },
        "name": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Literal": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "Literal" },
        "value": {}
      },
      "additionalProperties": false
    },
    "Metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null", "array", "object"]
      }
    }
  }
}
